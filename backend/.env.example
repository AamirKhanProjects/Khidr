# ---- Khidr backend env. Copy to .env.local and fill. NEVER commit .env.local. ----

# Supabase (server-side only — do NOT prefix with NEXT_PUBLIC).
# Project URL from Supabase dashboard, e.g. https://abcd.supabase.co
SUPABASE_URL=
# Service role key (server-side only). Full DB access — keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Admin auth (single operator).
# A strong password you choose. Used to log into /admin.
ADMIN_PASSWORD=
# Random 32+ byte secret for signing the session cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Public base URL of this deployment (used in a few places). Optional in dev.
# e.g. https://khidr-backend.vercel.app
APP_URL=
